{
  "name": "repomoddinbot",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "start": "bun --env-file=.env ./src/index.tsx",
    "deploy-server": "bun --env-file=.env.deploy ./src/deploy-server.ts",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "discord.js": "^14.25.1",
    "node-color-log": "^13.0.3"
  }
}